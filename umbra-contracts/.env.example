# Hardhat configuration variables (preferred over .env, set with):
#   npx hardhat vars set MNEMONIC
#   npx hardhat vars set INFURA_API_KEY
#   npx hardhat vars set ETHERSCAN_API_KEY
#
# This file documents what's needed if you'd rather use a .env file
# with dotenv in hardhat.config.ts instead.

MNEMONIC="your twelve word seed phrase goes here for sepolia deploys only"
INFURA_API_KEY="your infura project id"
ETHERSCAN_API_KEY="your etherscan v2 api key"

# ⚠️ IMPORTANT: never commit a real .env file or real mnemonic.
# Use a dedicated burner wallet for Sepolia testnet deploys.
